# ============================================================
# ScholarMind Environment Configuration
# ============================================================
# Copy this file to .env and update the values
#
# TWO MODES:
#   1. LOCAL (Docker):  docker compose up -d  → uses localhost URLs
#   2. CLOUD (No Docker): Sign up for free-tier managed services
#
# This file is configured for CLOUD mode by default.
# For Docker mode, uncomment the Docker lines and comment out
# the cloud lines.
# ============================================================

# ============================================================
# APPLICATION SETTINGS
# ============================================================
APP_NAME=ScholarMind
APP_ENV=development
DEBUG=true
# IMPORTANT: Generate a real key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-this-in-production-use-a-random-string
LOG_LEVEL=INFO

# ============================================================
# API SETTINGS
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ============================================================
# LLM - Google Gemini (REQUIRED for AI features)
# Get your API key from: https://makersuite.google.com/app/apikey
# ============================================================
GOOGLE_API_KEY=your-google-api-key-here

# ============================================================
# DATABASE - PostgreSQL
# ============================================================
# --- CLOUD: Neon (https://neon.tech — free tier: 0.5GB) ---
# Sign up → Create project → Copy connection string
# Neon gives you: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname
# Add ?sslmode=require and swap driver to asyncpg
POSTGRES_HOST=ep-example.us-east-1.aws.neon.tech
POSTGRES_PORT=5432
POSTGRES_DB=scholarmind
POSTGRES_USER=your-neon-username
POSTGRES_PASSWORD=your-neon-password
DATABASE_URL=postgresql+asyncpg://your-neon-username:your-neon-password@ep-example.us-east-1.aws.neon.tech/scholarmind?sslmode=require

# --- DOCKER: Uncomment these and comment out the above ---
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=scholarmind
# POSTGRES_USER=scholarmind
# POSTGRES_PASSWORD=scholarmind123
# DATABASE_URL=postgresql+asyncpg://scholarmind:scholarmind123@localhost:5432/scholarmind

# ============================================================
# KNOWLEDGE GRAPH - Neo4j
# ============================================================
# --- CLOUD: Neo4j AuraDB (https://neo4j.com/aura — free instance) ---
# Sign up → Create Free Instance → Copy credentials
# AuraDB gives you: neo4j+s://xxxx.databases.neo4j.io
NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-auradb-password

# --- DOCKER: Uncomment these and comment out the above ---
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=scholarmind123

# ============================================================
# CACHE & MESSAGE BROKER - Redis
# ============================================================
# --- CLOUD: Upstash (https://upstash.com — free: 10K commands/day) ---
# Sign up → Create Redis Database → Copy REST URL + Token
# Upstash gives you: rediss://default:token@region.upstash.io:6379
REDIS_HOST=your-instance.upstash.io
REDIS_PORT=6379
REDIS_URL=rediss://default:your-upstash-token@your-instance.upstash.io:6379
CELERY_BROKER_URL=rediss://default:your-upstash-token@your-instance.upstash.io:6379/1
CELERY_RESULT_BACKEND=rediss://default:your-upstash-token@your-instance.upstash.io:6379/2

# --- DOCKER: Uncomment these and comment out the above ---
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================================
# OBJECT STORAGE - MinIO / Local
# ============================================================
# For cloud deployment, you can use local filesystem (default)
# or switch to Cloudflare R2 / AWS S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=scholarmind
MINIO_SECRET_KEY=scholarmind123
MINIO_BUCKET=documents
MINIO_SECURE=false

# ============================================================
# VECTOR STORE - ChromaDB (runs locally, no external service)
# ============================================================
VECTOR_STORE_TYPE=chromadb
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=scholarmind_docs

# ============================================================
# ML MODELS
# ============================================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ============================================================
# FILE STORAGE (local directories — created automatically)
# ============================================================
UPLOAD_DIR=./data/uploads
PROCESSED_DIR=./data/processed
EMBEDDINGS_DIR=./data/embeddings
MAX_UPLOAD_SIZE_MB=100

# ============================================================
# LOGGING
# ============================================================
LOG_FORMAT=json

# ============================================================
# CORS SETTINGS
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# FRONTEND
# ============================================================
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000/api/v1
